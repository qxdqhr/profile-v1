# 复制为 config/android-signing.env（勿提交 Git）
# TeachHub Mobile 与 Calendar Mobile 共用同一套 release 签名（GitHub Secrets 同名）。

ANDROID_KEYSTORE_BASE64=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=teachhub
ANDROID_KEY_PASSWORD=

# 可选：若已用 apps/teach-hub-mobile/scripts/gen-android-keystore.sh 生成本地 jks，
# 可只填上面三个密码/alias，脚本会自动读取 apps/teach-hub-mobile/teach-hub-release.jks 并编码 BASE64。
