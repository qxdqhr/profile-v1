# 复制为 .env（Expo 会读取 EXPO_PUBLIC_*）

# Auth 服务（主站，Better Auth API）
EXPO_PUBLIC_AUTH_BASE_URL=http://localhost:3000

# TeachHub API（子应用）
EXPO_PUBLIC_TEACH_HUB_API_BASE_URL=http://localhost:3002

# Android 模拟器访问本机时可用：
# EXPO_PUBLIC_AUTH_BASE_URL=http://10.0.2.2:3000
# EXPO_PUBLIC_TEACH_HUB_API_BASE_URL=http://10.0.2.2:3002

# 生产网关（同域子路径）：
# EXPO_PUBLIC_AUTH_BASE_URL=https://your-domain.com
# EXPO_PUBLIC_TEACH_HUB_API_BASE_URL=https://your-domain.com/teach-hub
