# apps/calendar 本地开发环境变量模板
# 复制为 apps/calendar/.env.local
# 数据库 / Auth / AI 等共享配置见仓库根 config/app.config.local.yaml

# --- 服务 ---
# PORT=3001
# NEXT_DIST_DIR=.next-calendar

# --- 网关 basePath（生产 nginx 同域 /calendar 时必填）---
# NEXT_PUBLIC_BASE_PATH=/calendar

# --- Auth 公网 URL（与主站一致；缺省从 app.config auth.publicUrl 读取）---
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# APP_CONFIG_PATH=../../config/app.config.local.yaml
# APP_CONFIG_ENV=development
