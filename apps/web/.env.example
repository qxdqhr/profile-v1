# apps/web 本地开发环境变量模板
# 复制为 apps/web/.env.local（Next.js 自动加载）
# 数据库 / Auth / OSS 等主配置优先使用仓库根 config/app.config.local.yaml

# --- 子应用入口（链接跳转，非 API 反代）---
# 网关同域部署时使用相对路径；独立端口开发时使用完整 URL
# NEXT_PUBLIC_CALENDAR_URL=/calendar
# NEXT_PUBLIC_CALENDAR_URL=http://localhost:3001
# NEXT_PUBLIC_TEACH_HUB_URL=/teach-hub
# NEXT_PUBLIC_TEACH_HUB_URL=http://localhost:3002

# --- AI（可选，覆盖 app.config 中 ai 节）---
# AI_API_KEY=sk-your-mimo-api-key
# AI_BASE_URL=https://api.xiaomimimo.com/v1
# AI_VISION_MODEL=mimo-v2.5
# AI_TEXT_MODEL=mimo-v2.5

# --- 构建 ---
# NEXT_DIST_DIR=.next
# APP_CONFIG_PATH=../../config/app.config.local.yaml
# APP_CONFIG_ENV=development
