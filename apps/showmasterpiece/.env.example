# apps/showmasterpiece 本地开发环境变量模板
# 复制为 apps/showmasterpiece/.env.local

# PORT=3003
# NEXT_DIST_DIR=.next-showmasterpiece

# 网关 basePath（生产 nginx 同域 /showmasterpiece 时必填）
# NEXT_PUBLIC_BASE_PATH=/showmasterpiece

# Auth 公网 URL（与主站一致）
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# APP_CONFIG_PATH=../../config/app.config.local.yaml
