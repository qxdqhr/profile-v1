# 复制为 .env（Expo 会读取 EXPO_PUBLIC_*）

# Auth 服务（主站，Better Auth API）
EXPO_PUBLIC_AUTH_BASE_URL=http://localhost:3000

# Calendar API（子应用）
EXPO_PUBLIC_CALENDAR_API_BASE_URL=http://localhost:3001

# Calendar Web 入口（登录 WebView，默认同 API 或生产 /calendar）
# EXPO_PUBLIC_CALENDAR_WEB_BASE_URL=http://localhost:3001
# EXPO_PUBLIC_CALENDAR_WEB_BASE_URL=https://your-domain.com/calendar

# Android 模拟器访问本机时可用：
# EXPO_PUBLIC_AUTH_BASE_URL=http://10.0.2.2:3000
# EXPO_PUBLIC_CALENDAR_API_BASE_URL=http://10.0.2.2:3001

# 生产网关（同域子路径）：
# EXPO_PUBLIC_AUTH_BASE_URL=https://your-domain.com
# EXPO_PUBLIC_CALENDAR_API_BASE_URL=https://your-domain.com/calendar
