{
  "name": "personal-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:sync-sa2kit": "rm -rf ./.next && gg pnpm up sa2kit@latest && gg pnpm install && next dev --webpack",
    "dev:3002": "NEXT_DIST_DIR=.next-3002 next dev --webpack -p 3002",
    "dev:3003": "NEXT_DIST_DIR=.next-3003 next dev --webpack -p 3003",
    "dev:https": "next dev --webpack --experimental-https",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "config:doctor": "tsx --import ./scripts/preload-app-config.ts scripts/config-doctor.ts",
    "config:verify-business": "tsx --import ./scripts/preload-app-config.ts scripts/verify-business-config.ts",
    "config:sops-init": "bash scripts/config-sops-init.sh",
    "config:encrypt-production": "bash scripts/config-encrypt-production.sh",
    "config:decrypt-production": "bash scripts/config-decrypt-production.sh",
    "config:install-sops": "bash scripts/install-sops.sh",
    "devdb:generate": "tsx --import ./scripts/preload-app-config.ts node_modules/drizzle-kit/bin.cjs generate",
    "devdb:push": "tsx --import ./scripts/preload-app-config.ts scripts/ensure-auth-enum.ts && tsx --import ./scripts/preload-app-config.ts scripts/drizzle-push.ts",
    "devdb:migrate": "tsx --import ./scripts/preload-app-config.ts src/db/migrate.ts",
    "devdb:studio": "tsx --import ./scripts/preload-app-config.ts node_modules/drizzle-kit/bin.cjs studio --port 3500",
    "prodb:generate": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts node_modules/drizzle-kit/bin.cjs generate",
    "prodb:push": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/ensure-auth-enum.ts && APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/ensure-orphan-user-records.ts && APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/drizzle-push.ts",
    "prodb:migrate": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts src/db/migrate.ts",
    "prodb:studio": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts node_modules/drizzle-kit/bin.cjs studio --port 3500",
    "prodb:seed": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/create-prod-masterpieces-data.ts",
    "prodb:users": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/create-prod-user-data.ts",
    "prodb:verify": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/verify-prod-data.ts",
    "devdb:createusers": "tsx --import ./scripts/preload-app-config.ts scripts/create-test-user-accounts.ts",
    "prodb:createusers": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/create-test-user-accounts.ts",
    "devdb:queryusers": "tsx --import ./scripts/preload-app-config.ts scripts/query-all-users.ts",
    "prodb:queryusers": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/query-all-users.ts",
    "devdb:migrate:festivalcard": "tsx --import ./scripts/preload-app-config.ts scripts/migrate-festival-card.ts",
    "prodb:migrate:festivalcard": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/migrate-festival-card.ts",
    "test:oss": "node scripts/test-oss-config.js",
    "test:upload": "tsx --import ./scripts/preload-app-config.ts scripts/test-upload.ts",
    "test:skill-manager:validation": "tsx scripts/skill-manager-validation-test.ts",
    "fix:storage-provider": "tsx --import ./scripts/preload-app-config.ts scripts/fix-default-storage-provider.ts",
    "fix:storage-provider:prod": "APP_CONFIG_ENV=production tsx --import ./scripts/preload-app-config.ts scripts/fix-default-storage-provider.ts",
    "ticket-monitor:sync": "tsx --import ./scripts/preload-app-config.ts src/modules/ticketMonitor/scripts/run-sync.ts"
  },
