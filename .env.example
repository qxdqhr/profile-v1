# 可选：覆盖 config/app.config.local.yaml 中的 ai 节（Next.js 自动加载 .env.local）
# 复制为 .env.local 后填写；生产环境请写入 app.config.production.plain.yaml 并 SOPS 加密

# 小米 MiMo（OpenAI 兼容）
AI_API_KEY=sk-your-mimo-api-key
AI_BASE_URL=https://api.xiaomimimo.com/v1
AI_VISION_MODEL=mimo-v2.5
AI_TEXT_MODEL=mimo-v2.5

# Token Plan 用户请改用订阅管理页提供的 Base URL，例如：
# AI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# AI_API_KEY=tp-your-token-plan-key
